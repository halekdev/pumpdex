# Neon Postgres connection string (Vercel Postgres / Neon dashboard)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Helius RPC API keys (https://helius.dev). FALLBACK is optional but recommended
# so requests survive a single key being rate-limited.
HELIUS_KEY=your-helius-api-key
HELIUS_KEY_FALLBACK=your-second-helius-api-key

# Shared secret protecting the privileged endpoints (/api/migrate, /api/sync) and
# the Vercel cron job (/api/cron/snapshot). Set the SAME value in the Vercel
# project settings so cron invocations are authorized automatically.
# Generate one with:  openssl rand -hex 32
CRON_SECRET=change-me

# Telegram bot (https://t.me/BotFather). NEVER commit the real token.
TELEGRAM_BOT_TOKEN=123456:your-bot-token
# Random secret Telegram echoes back on every webhook call so we can verify it.
# Generate with:  openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=change-me

# Public base URL of the deployed site, used in bot links (no trailing slash).
SITE_URL=https://pumpdex.io
# Where the Telegram webhook should point (defaults to SITE_URL if unset).
PUBLIC_URL=https://pumpdex.io
